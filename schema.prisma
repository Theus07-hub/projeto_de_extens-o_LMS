model usuario {
    id     Int    @id @default(autoincrement())
    nome   String
    email  String @unique
    senha  String
    foto_perfil String?
}

datasource db {
    provider = "mysql"
    url      = env("DATABASE_URL")
}

generator client {
    provider      = "prisma-client-js"
    binaryTargets = ["native", "debian-openssl-3.0.x"]
}