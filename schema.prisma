
generator client{
    provider = "prisma-client-js"
    binaryTargets = ["native", "debian-openssl-3.0.x"]
}

model Usuarios {
    id Int @id @default(autoincrement()) 
    name String
    email String @unique
    senha String
}

datasource db {
    provider = "mysql"
    url = env("DATABASE_URL")
}